# Moshtari — Local Deployment Configuration
# Copy this file as .env next to the executable and adjust as needed.

# Database type: "sqlite" (default, zero setup) or "postgres"
DATABASE_TYPE=sqlite

# SQLite: path to the database file (sqlite:/// prefix)
# PostgreSQL: postgresql://user:password@host:5432/moshtari
DATABASE_URL=sqlite:///./data/moshtari.db

# Server settings
HOST=0.0.0.0
PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Directory containing XGBoost model files (.json) and ARIMA caches (.pkl)
MODELS_DIR=./models
